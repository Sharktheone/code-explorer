import { Button, CheckBox, ComboBox, LineEdit, ListView, ScrollView, Slider } from "std-widgets.slint";

export struct LanguageSegment {
    name: string,
    color: brush,
    percent: float,
    label: string,
    tooltip: string,
}

export struct DirectoryRow {
    path: string,
    name: string,
    kind: string,
    is_directory: bool,
    metric: string,
    percent: string,
    percent_value: float,
    files: string,
    language: string,
    language_color: brush,
    attention_color: brush,
    tooltip: string,
    row_bar: [LanguageSegment],
}

export struct BoxRect {
    path: string,
    label: string,
    color: brush,
    value: string,
    x: float,
    y: float,
    width: float,
    height: float,
    tooltip: string,
}

export struct BreadcrumbSegment {
    label: string,
    path: string,
}

component FolderIcon inherits Rectangle {
    width: 16px;
    height: 13px;
    background: transparent;
    Rectangle { x: 1px; y: 4px; width: 14px; height: 8px; border-radius: 2px; background: #d29922; }
    Rectangle { x: 2px; y: 1px; width: 7px; height: 5px; border-radius: 2px; background: #e3b341; }
}

component FileIcon inherits Rectangle {
    width: 14px;
    height: 16px;
    background: transparent;
    Rectangle { x: 2px; y: 1px; width: 10px; height: 14px; border-radius: 2px; background: #8b949e; }
    Rectangle { x: 8px; y: 1px; width: 4px; height: 4px; background: #c9d1d9; }
}

component StatCell inherits Rectangle {
    in property <string> value;
    in property <string> label;
    background: transparent;
    Text {
        y: 6px;
        width: parent.width;
        text: root.value;
        color: #ffffff;
        font-size: 18px;
        font-weight: 700;
        horizontal-alignment: center;
    }
    Text {
        y: 34px;
        width: parent.width;
        text: root.label;
        color: #8b949e;
        font-size: 11px;
        horizontal-alignment: center;
    }
}

export component AppWindow inherits Window {
    preferred-width: 1180px;
    preferred-height: 760px;
    min-width: 720px;
    min-height: 480px;
    title: "Code Explorer";

    in-out property <string> current-source: "";
    in-out property <string> breadcrumb: "";
    in-out property <string> current-dir-name: "";
    in-out property <string> current-total-loc: "";
    in-out property <string> current-code-loc: "";
    in-out property <string> current-comment-loc: "";
    in-out property <string> current-blank-loc: "";
    in-out property <string> current-files: "";
    in-out property <string> current-language: "";
    in-out property <[BreadcrumbSegment]> breadcrumb-segments;
    in-out property <string> status-text: "Open a folder or pass a directory argument.";
    in-out property <int> metric-index: 0;
    in-out property <int> view-index: 0;
    in-out property <bool> show-row-bars: true;
    in-out property <float> subdir-limit: 40;
    in-out property <[LanguageSegment]> language-segments;
    in-out property <[DirectoryRow]> directory-rows;
    in-out property <bool> directory-empty: true;
    in-out property <[BoxRect]> box-rects;
    in-out property <string> clone-url: "";
    in-out property <string> include-extensions: "";
    in-out property <string> exclude-extensions: "";
    in-out property <string> include-languages: "";
    in-out property <string> exclude-languages: "";
    in-out property <string> exclude-dirs: "";
    in-out property <bool> respect-gitignore: true;
    in-out property <bool> include-hidden: false;
    in-out property <string> max-depth: "";

    callback open-folder();
    callback clone-repository(string);
    callback rescan();
    callback metric-changed(int);
    callback view-changed(int);
    callback row-bars-changed(bool);
    callback filters-changed();
    callback subdir-limit-changed(float);
    callback enter-directory(string);
    callback go-up();

    // Top toolbar
    HorizontalLayout {
        x: 12px;
        y: 12px;
        width: root.width - 24px;
        height: 34px;
        spacing: 8px;
        Button { text: "Open Folder"; clicked => { root.open-folder(); } }
        LineEdit {
            text <=> root.clone-url;
            placeholder-text: "https://github.com/user/repo.git";
            horizontal-stretch: 1;
        }
        Button { text: "Clone"; clicked => { root.clone-repository(root.clone-url); } }
        Button { text: "Rescan"; clicked => { root.rescan(); } }
        Text {
            text: root.current-source;
            color: #f0f6fc;
            horizontal-stretch: 1;
            overflow: elide;
            vertical-alignment: center;
        }
    }

    // Language summary
    Rectangle {
        x: 12px;
        y: 56px;
        width: root.width - 24px;
        height: 72px;
        background: #0d1117;
        border-radius: 6px;
        Rectangle {
            x: 10px;
            y: 10px;
            width: parent.width - 20px;
            height: 10px;
            border-radius: 5px;
            clip: true;
            background: #30363d;
            HorizontalLayout {
                width: parent.width;
                height: parent.height;
                spacing: 0px;
                for segment in root.language-segments: Rectangle {
                    height: parent.height;
                    width: max(1px, segment.percent * (parent.width / 100));
                    background: segment.color;
                    Tooltip { text: @markdown("\{segment.tooltip}"); }
                }
            }
        }
        HorizontalLayout {
            x: 10px;
            y: 32px;
            width: parent.width - 20px;
            height: 24px;
            spacing: 18px;
            for segment in root.language-segments: HorizontalLayout {
                spacing: 6px;
                Rectangle {
                    width: 9px;
                    height: 9px;
                    border-radius: 5px;
                    background: segment.color;
                    vertical-stretch: 0;
                    Tooltip { text: @markdown("\{segment.tooltip}"); }
                }
                Text {
                    text: segment.label;
                    color: #f0f6fc;
                    font-size: 13px;
                    Tooltip { text: @markdown("\{segment.tooltip}"); }
                }
            }
        }
    }

    // Filters sidebar
    ScrollView {
        x: 12px;
        y: 140px;
        width: 280px;
        height: root.height - 152px;
        VerticalLayout {
            padding-right: 8px;
            spacing: 8px;
            Text { text: "Filters"; font-size: 18px; font-weight: 700; }
            Text { text: "Metric"; }
            ComboBox {
                model: ["Total LOC", "Code LOC", "Files"];
                current-index <=> root.metric-index;
                selected(_) => { root.metric-changed(root.metric-index); }
            }
            Text { text: "View"; }
            ComboBox {
                model: ["Directory List", "Boxes Grid"];
                current-index <=> root.view-index;
                selected(_) => { root.view-changed(root.view-index); }
            }
            CheckBox { text: "Show row language bars"; checked <=> root.show-row-bars; toggled => { root.row-bars-changed(root.show-row-bars); } }
            CheckBox { text: "Respect .gitignore"; checked <=> root.respect-gitignore; toggled => { root.filters-changed(); } }
            CheckBox { text: "Include hidden files"; checked <=> root.include-hidden; toggled => { root.filters-changed(); } }
            Text { text: "Max depth"; }
            LineEdit { text <=> root.max-depth; placeholder-text: "unlimited"; }
            Text { text: "Include extensions"; }
            LineEdit { text <=> root.include-extensions; }
            Text { text: "Exclude extensions"; }
            LineEdit { text <=> root.exclude-extensions; }
            Text { text: "Include languages"; }
            LineEdit { text <=> root.include-languages; }
            Text { text: "Exclude languages"; }
            LineEdit { text <=> root.exclude-languages; }
            Text { text: "Exclude dirs"; }
            LineEdit { text <=> root.exclude-dirs; }
            Button { text: "Apply Filters"; clicked => { root.filters-changed(); } }
            Text { text: "Subdirs shown"; }
            Slider {
                minimum: 5;
                maximum: 200;
                value <=> root.subdir-limit;
                changed => { root.subdir-limit-changed(root.subdir-limit); }
            }
            Text { text: "Legend: red top 10%, orange top 25%, yellow top 50%, blue small, gray empty, purple vendor."; wrap: word-wrap; color: #57606a; }
        }
    }

    // Main content panel
    Rectangle {
        x: 304px;
        y: 140px;
        width: root.width - 316px;
        height: root.height - 152px;
        background: transparent;

        Button {
            x: 0px;
            y: 0px;
            width: 44px;
            height: 30px;
            text: "Up";
            clicked => { root.go-up(); }
        }

        Rectangle {
            x: 52px;
            y: 0px;
            width: parent.width - 52px;
            height: 30px;
            clip: true;
            HorizontalLayout {
                spacing: 4px;
                for segment[i] in root.breadcrumb-segments: Rectangle {
                    height: 30px;
                    width: max(42px, crumb-text.preferred-width + (i > 0 ? 30px : 16px));
                    horizontal-stretch: 0;
                    if i > 0: Text {
                        x: 0px;
                        y: (parent.height - self.preferred-height) / 2;
                        width: 14px;
                        text: "/";
                        color: #8b949e;
                        horizontal-alignment: center;
                    }
                    Rectangle {
                        x: i > 0 ? 18px : 0px;
                        y: 0px;
                        width: parent.width - (i > 0 ? 18px : 0px);
                        height: 30px;
                        border-radius: 4px;
                        background: crumb-touch.has-hover ? #30363d : transparent;
                        crumb-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.enter-directory(segment.path); }
                        }
                        crumb-text := Text {
                            x: 8px;
                            y: (parent.height - self.preferred-height) / 2;
                            width: parent.width - 16px;
                            text: segment.label;
                            color: #f0f6fc;
                            font-size: 13px;
                            overflow: elide;
                        }
                        Tooltip { text: @markdown("\{segment.path}"); }
                    }
                }
            }
        }

        if root.view-index == 0: Rectangle {
            x: 0px;
            y: 38px;
            width: parent.width;
            height: parent.height - 38px;
            background: transparent;

            Rectangle {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: 58px;
                background: #242424;
                border-color: #30363d;
                border-width: 1px;
                border-radius: 6px;
                HorizontalLayout {
                    x: 12px;
                    y: 0px;
                    width: parent.width - 24px;
                    height: parent.height;
                    spacing: 10px;
                    VerticalLayout {
                        horizontal-stretch: 2;
                        min-width: 170px;
                        Text { text: root.current-dir-name; color: #f0f6fc; font-size: 18px; font-weight: 700; overflow: elide; vertical-alignment: center; }
                        Text { text: root.current-language; color: #8b949e; font-size: 12px; overflow: elide; vertical-alignment: center; }
                    }
                    StatCell { value: root.current-total-loc; label: "Total LOC"; horizontal-stretch: 1; }
                    StatCell { value: root.current-code-loc; label: "Code"; horizontal-stretch: 1; }
                    StatCell { value: root.current-comment-loc; label: "Comments"; horizontal-stretch: 1; }
                    StatCell { value: root.current-blank-loc; label: "Blanks"; horizontal-stretch: 1; }
                    StatCell { value: root.current-files; label: "Files"; horizontal-stretch: 1; }
                }
            }

            HorizontalLayout {
                x: 0px;
                y: 66px;
                width: parent.width;
                height: 28px;
                Text { text: ""; width: 18px; }
                Text { text: "Directory"; horizontal-stretch: 1; min-width: 260px; color: #f0f6fc; font-weight: 700; }
                Text { text: "LOC"; width: 140px; color: #f0f6fc; font-weight: 700; horizontal-alignment: center; }
                Text { text: "%"; width: 130px; color: #f0f6fc; font-weight: 700; horizontal-alignment: center; }
                Text { text: "Files"; width: 80px; color: #f0f6fc; font-weight: 700; horizontal-alignment: center; }
                Text { text: "Language"; width: 160px; color: #f0f6fc; font-weight: 700; }
            }

            if !root.directory-empty: ListView {
                x: 0px;
                y: 96px;
                width: parent.width;
                height: max(0px, parent.height - 120px);
                for row in root.directory-rows: Rectangle {
                    height: root.show-row-bars ? 50px : 38px;
                    background: transparent;
                    Tooltip { text: @markdown("\{row.tooltip}"); }
                    touch := TouchArea {
                        mouse-cursor: row.is_directory ? pointer : default;
                        clicked => {
                            if row.is_directory {
                                root.enter-directory(row.path);
                            }
                        }
                    }
                    Rectangle {
                        x: 0px;
                        y: 3px;
                        width: parent.width;
                        height: parent.height - 6px;
                        background: touch.has-hover ? #2d2d2d : #242424;
                        border-color: touch.has-hover ? #57606a : #30363d;
                        border-width: 1px;
                        border-radius: 6px;
                        Rectangle { x: 0px; y: 0px; width: 4px; height: parent.height; background: row.attention_color; }
                        Rectangle { x: 16px; y: (parent.height - 10px) / 2; width: 10px; height: 10px; border-radius: 5px; background: row.language_color; }
                        if row.is_directory: FolderIcon { x: 38px; y: (parent.height - self.height) / 2; }
                        if !row.is_directory: FileIcon { x: 39px; y: (parent.height - self.height) / 2; }
                        Text {
                            x: 62px;
                            y: root.show-row-bars ? 7px : (parent.height - self.preferred-height) / 2;
                            width: max(120px, parent.width - 62px - 140px - 130px - 80px - 160px - 44px);
                            text: row.name;
                            color: row.is_directory ? #f0f6fc : #d0d7de;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                        if root.show-row-bars: Rectangle {
                            x: 62px;
                            y: 30px;
                            width: max(120px, parent.width - 62px - 140px - 130px - 80px - 160px - 44px);
                            height: 6px;
                            border-radius: 3px;
                            clip: true;
                            background: #30363d;
                            HorizontalLayout {
                                width: parent.width;
                                height: parent.height;
                                spacing: 0px;
                                for segment in row.row_bar: Rectangle {
                                    height: 6px;
                                    width: max(1px, segment.percent * (parent.width / 100));
                                    background: segment.color;
                                    Tooltip { text: @markdown("\{segment.tooltip}"); }
                                }
                            }
                        }
                        Text {
                            x: parent.width - 140px - 130px - 80px - 160px - 28px;
                            y: (parent.height - self.preferred-height) / 2;
                            width: 140px;
                            text: row.metric;
                            color: #ffffff;
                            font-size: 16px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        Rectangle {
                            x: parent.width - 130px - 80px - 160px - 28px;
                            y: (parent.height - 18px) / 2;
                            width: 130px;
                            height: 18px;
                            background: #161b22;
                            border-radius: 9px;
                            Rectangle {
                                x: 2px;
                                y: 2px;
                                width: max(2px, (parent.width - 4px) * row.percent_value / 100);
                                height: parent.height - 4px;
                                background: row.attention_color;
                                border-radius: 7px;
                            }
                            Text {
                                text: row.percent;
                                color: #f0f6fc;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Text {
                            x: parent.width - 80px - 160px - 20px;
                            y: (parent.height - self.preferred-height) / 2;
                            width: 80px;
                            text: row.files;
                            color: #d0d7de;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        Text {
                            x: parent.width - 160px - 8px;
                            y: (parent.height - self.preferred-height) / 2;
                            width: 150px;
                            text: row.language;
                            color: #f0f6fc;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            if root.directory-empty: Rectangle {
                x: 0px;
                y: 96px;
                width: parent.width;
                height: max(86px, parent.height - 120px);
                background: #242424;
                border-color: #30363d;
                border-width: 1px;
                border-radius: 6px;
                Text {
                    text: "No files or subdirectories match the current filters.";
                    color: #8b949e;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        if root.view-index == 1: Rectangle {
            x: 0px;
            y: 38px;
            width: parent.width;
            height: parent.height - 62px;
            background: #f6f8fa;
            border-color: #d0d7de;
            border-width: 1px;
            for box in root.box-rects: Rectangle {
                x: box.x * parent.width;
                y: box.y * parent.height;
                width: box.width * parent.width;
                height: box.height * parent.height;
                background: box.color;
                border-color: #ffffff;
                border-width: 2px;
                Tooltip { text: @markdown("\{box.tooltip}"); }
                if box.width * parent.width > 52px && box.height * parent.height > 28px: Rectangle {
                    x: 6px;
                    y: 6px;
                    width: parent.width - 12px;
                    height: min(parent.height - 12px, 42px);
                    background: #00000066;
                    border-radius: 3px;
                    Text {
                        x: 6px;
                        y: 5px;
                        width: parent.width - 12px;
                        text: box.label;
                        color: #ffffff;
                        font-size: parent.height > 50px ? 13px : 11px;
                        overflow: elide;
                    }
                    if parent.height > 48px: Text {
                        x: 6px;
                        y: 22px;
                        width: parent.width - 12px;
                        text: box.value;
                        color: #ffffffcc;
                        font-size: 11px;
                        overflow: elide;
                    }
                }
                TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.enter-directory(box.path); }
                }
            }
        }

        Text {
            x: 0px;
            y: parent.height - 18px;
            width: parent.width;
            text: root.status-text;
            color: #8b949e;
            overflow: elide;
        }
    }
}
